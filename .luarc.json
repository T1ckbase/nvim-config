{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "format.enable": false,
  "workspace": {
    "library": [
      "$VIMRUNTIME/lua",
      "~/AppData/Local/nvim-data/site/pack/deps",
      "${3rd}/luv/library"
    ],
    "checkThirdParty": false
  }
}
