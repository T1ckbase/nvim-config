{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "format": {
    "enable": true,
    "defaultConfig": {
      "quote_style": "single",
      "max_line_length": "120",
      "end_of_line": "lf",
      "align_continuous_assign_statement": "false"
    }
  },
  "workspace": {
    "library": [
      "$VIMRUNTIME/lua",
      "${3rd}/luv/library"
    ],
    "checkThirdParty": false
  }
}
